# Copiar a /etc/genaudius/mcp.env en el VPS (chmod 600)
GENAUDIUS_API_KEY=changeme
MODAL_WEBHOOK_TOKEN=changeme

# Mínimo para GAU + training trigger
MODAL_AUDIO_URL=https://YOUR-WORKSPACE--genaudius-api.modal.run

# Opcionales (Modal directo o URL AWS API Gateway → Modal)
MODAL_IMAGE_URL=
MODAL_VIDEO_URL=
MODAL_COMPOSER_URL=
MODAL_CHATGAU_URL=
MODAL_STEMS_URL=
MODAL_MIDI_URL=
MODAL_BUILDER_URL=
MODAL_ANALYTICS_URL=
MODAL_GATEWAY_URL=

GENAUDIUS_VERSION=GenAudius_V1
TIME_OUT_SECONDS=600
