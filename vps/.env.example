# ═══════════════════════════════════════════════════════════════════
# GenAudius MCP VPS — .env
# VPS:     genaudius.cloud    (Hostinger)
# SaaS:    genaudius.com    (AWS)
# Motores: genaudius.studio (Modal)
# ═══════════════════════════════════════════════════════════════════

SSL_EMAIL=admin@genaudius.cloud

# MCP Auth
GENAUDIUS_API_KEY=CAMBIAR_POR_KEY_SEGURA_256_BITS

# Modal endpoints (genaudius.studio)
MODAL_AUDIO_URL=https://genaudius-audio-api.genaudius.studio
MODAL_IMAGE_URL=https://genaudius-image-api.genaudius.studio
MODAL_VIDEO_URL=https://genaudius-video-api.genaudius.studio
MODAL_COMPOSER_URL=https://genaudius-composer-lyric-api.genaudius.studio
MODAL_CHATGAU_URL=https://genaudius-chatgau-api.genaudius.studio
MODAL_STEMS_URL=https://genaudius-stems-api.genaudius.studio
MODAL_MIDI_URL=https://genaudius-midi-api.genaudius.studio
MODAL_BUILDER_URL=https://genaudius-prompt-builder-api.genaudius.studio
MODAL_ANALYTICS_URL=https://genaudius-analytics-api.genaudius.studio
MODAL_GATEWAY_URL=https://genaudius-gateway.genaudius.studio
MODAL_WEBHOOK_TOKEN=CAMBIAR_POR_TOKEN_MODAL_SEGURO

# Config
GENAUDIUS_VERSION=GenAudius_V1
TIME_OUT_SECONDS=600
